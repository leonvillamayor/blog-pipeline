# Copiar a .env y rellenar. NUNCA commitear .env.

# === GitHub PAT fine-grained con scopes:
#     - Contents: Read+Write
#     - Pull requests: Read+Write
#     - Actions: Read+Write
#     - Metadata: Read
#     sobre el repo leonvillamayor/blog
GITHUB_TOKEN=github_pat_...

# === Cloudflare API token (mismo cfut_ que usa el resto de tooling)
#     Permisos requeridos: Pages Read, Cloudflare Tunnel Read (para mostrar
#     status de builds y de tunnel en la GUI).
CLOUDFLARE_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=77771c03b86036457910b97bc061626d
CLOUDFLARE_ZONE_ID=b1093981dc5e4732400cf958912cf63d

# === Repo del blog que la GUI gestiona
BLOG_REPO=leonvillamayor/blog
BLOG_REPO_PATH=/opt/blog-pipeline/data/repo

# === Convenciones
DRAFT_BRANCH_PREFIX=drafts/         # Patrón de feature branches "pendiente dev"
ARTICLE_PATH_PREFIX=content/posts/   # Path donde viven los artículos
INFRA_PATHS=layouts/,static/,themes/,hugo.toml,i18n/,data/,archetypes/,tools/,schema/,documentacion/

# === Bind / runtime
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info
REFRESH_INTERVAL_SECONDS=60
